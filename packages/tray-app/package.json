{
  "name": "@ma-browser/tray-app",
  "version": "0.0.1",
  "private": true,
  "description": "Windows system tray daemon UI for ma-browser",
  "type": "module",
  "scripts": {
    "panel:dev":   "cd src-panel && npm run dev",
    "panel:build": "cd src-panel && npm run build",
    "dev":         "tauri dev",
    "build":       "npm run panel:build",
    "tauri:build": "npm run panel:build && tauri build",
    "build:debug": "npm run panel:build && tauri build --debug"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  }
}
